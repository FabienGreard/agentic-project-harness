{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-project-harness.local/schemas/project-state.json",
  "title": "Agentic Project Harness state",
  "type": "object",
  "additionalProperties": false,
  "required": ["templateMode", "project", "baton", "tickets", "activeWork", "humanReviews"],
  "properties": {
    "templateMode": { "type": "boolean" },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "phase", "lastVerified"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "phase": { "type": "string", "minLength": 1 },
        "lastVerified": { "type": "string", "format": "date" }
      }
    },
    "baton": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "action", "returnTrigger"],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "returnTrigger": { "type": "string", "minLength": 1 }
      }
    },
    "tickets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "priority", "owner", "dependencies", "path"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9-]+$" },
          "status": {
            "enum": ["Idea", "Needs Definition", "PRD in Progress", "Ready", "Queued", "In Progress", "Dispatched", "Blocked", "Integration", "Verification", "In Review", "Completed", "Abandoned"]
          },
          "priority": { "enum": ["P0", "P1", "P2", "P3", "P4"] },
          "owner": { "type": "string", "minLength": 1 },
          "dependencies": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "path": { "type": "string", "minLength": 1 },
          "reportPath": { "type": "string" },
          "requiresSpecialistReview": { "type": "boolean" },
          "requiresHumanReview": { "type": "boolean" }
        }
      }
    },
    "activeWork": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ticket", "owner", "scopes", "status", "returnDestination"],
        "properties": {
          "ticket": { "type": "string" },
          "owner": { "type": "string", "minLength": 1 },
          "scopes": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
          "status": { "enum": ["Queued", "In Progress", "Dispatched", "Integration", "Verification", "In Review", "Blocked"] },
          "returnDestination": { "type": "string", "minLength": 1 }
        }
      }
    },
    "humanReviews": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "path"],
        "properties": {
          "id": { "type": "string" },
          "status": { "enum": ["Pending", "Approved", "Revision Requested", "Rejected"] },
          "path": { "type": "string" }
        }
      }
    }
  }
}
