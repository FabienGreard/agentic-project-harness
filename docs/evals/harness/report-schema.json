{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Harness evaluation report",
  "type": "object",
  "additionalProperties": false,
  "required": ["runId", "mode", "harnessRevision", "verdict", "hardGateFailures", "categoryScores", "totalScore", "findings", "recommendation"],
  "properties": {
    "runId": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["static", "scenario-smoke", "scenario-release", "live-trace"] },
    "harnessRevision": { "type": "string", "minLength": 1 },
    "verdict": { "enum": ["PASS", "WARN", "FAIL"] },
    "hardGateFailures": { "type": "array", "items": { "type": "string", "pattern": "^HG-[0-9]{2}$" }, "uniqueItems": true },
    "categoryScores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "baton", "safety", "parallelism", "advancement", "efficiency"],
      "properties": {
        "scope": { "type": "number", "minimum": 0, "maximum": 25 },
        "baton": { "type": "number", "minimum": 0, "maximum": 20 },
        "safety": { "type": "number", "minimum": 0, "maximum": 20 },
        "parallelism": { "type": "number", "minimum": 0, "maximum": 15 },
        "advancement": { "type": "number", "minimum": 0, "maximum": 10 },
        "efficiency": { "type": "number", "minimum": 0, "maximum": 10 }
      }
    },
    "totalScore": { "type": "number", "minimum": 0, "maximum": 100 },
    "findings": { "type": "array", "items": { "type": "object" } },
    "recommendation": { "enum": ["accept", "revise", "reject"] }
  }
}
