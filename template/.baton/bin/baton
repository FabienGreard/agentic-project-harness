#!/usr/bin/env python3
"""Baton's installed Repository command."""

from pathlib import Path
import os
import sys

sys.dont_write_bytecode = True

project_root = Path(__file__).absolute().parents[2]
os.environ.setdefault("BATON_PROJECT_ROOT", str(project_root))
sys.path.insert(0, str((project_root / ".baton/lib").resolve()))

from baton_cli import main

raise SystemExit(main(project_root))
