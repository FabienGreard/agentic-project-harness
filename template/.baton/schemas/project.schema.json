{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/FabienGreard/baton/blob/main/template/.baton/schemas/project.schema.json",
  "title": "Baton canonical project record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "recordType", "project", "baton"],
  "properties": {
    "schemaVersion": {"const": 1},
    "recordType": {"const": "project"},
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "outcome", "currentGoal", "agentProvider", "phase", "templateMode", "lastVerified", "assuranceDefaults"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "outcome": {"type": "string"},
        "currentGoal": {"type": "string"},
        "agentProvider": {"const": "codex"},
        "phase": {"type": "string", "minLength": 1},
        "templateMode": {"type": "boolean"},
        "lastVerified": {"type": "string"},
        "assuranceDefaults": {
          "type": "object",
          "additionalProperties": false,
          "required": ["testRigor", "humanReviewStages"],
          "properties": {
            "testRigor": {"enum": ["Lean", "Standard", "Thorough"]},
            "humanReviewStages": {
              "type": "array",
              "items": {"enum": ["Readiness", "Acceptance", "Release"]},
              "uniqueItems": true
            }
          }
        }
      }
    },
    "baton": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "action", "returnTrigger"],
      "properties": {
        "owner": {"type": "string", "minLength": 1},
        "action": {"type": "string", "minLength": 1},
        "returnTrigger": {"type": "string", "minLength": 1}
      }
    }
  }
}
