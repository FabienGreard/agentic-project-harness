{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/FabienGreard/baton/blob/main/template/.baton/schemas/ownership.schema.json",
  "title": "Baton canonical ownership record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "recordType", "ownership"],
  "properties": {
    "schemaVersion": {"const": 1},
    "recordType": {"const": "ownership"},
    "ownership": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ticket", "owner", "scopes", "status", "returnDestination"],
        "properties": {
          "ticket": {"type": "string", "minLength": 1},
          "owner": {"type": "string", "minLength": 1},
          "scopes": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true},
          "status": {"enum": ["Assigned", "Building", "Blocked", "Integrating", "Verifying", "Awaiting Review"]},
          "returnDestination": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
