{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/FabienGreard/baton/blob/main/template/.baton/schemas/goals.schema.json",
  "title": "Baton canonical goals record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "recordType", "goals"],
  "properties": {
    "schemaVersion": {"const": 1},
    "recordType": {"const": "goals"},
    "goals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "status", "priority", "owner", "objective", "context", "dependencies", "blockers", "decisionPaths", "evidencePaths"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Z][A-Z0-9-]+$"},
          "title": {"type": "string", "minLength": 1},
          "status": {"enum": ["Needs Definition", "Ready", "Active", "Review", "Done"]},
          "priority": {"enum": ["P0", "P1", "P2", "P3", "P4"]},
          "owner": {"type": "string", "minLength": 1},
          "objective": {"type": "string", "minLength": 1},
          "context": {"type": "string", "minLength": 1},
          "dependencies": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "blockerOwner": {"type": "string", "minLength": 1},
          "resumeCondition": {"type": "string", "minLength": 1},
          "narrativePath": {"type": "string", "minLength": 1},
          "decisionPaths": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "evidencePaths": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "plannedStart": {"type": "string", "format": "date"},
          "plannedEnd": {"type": "string", "format": "date"},
          "resultSummary": {"type": "string", "minLength": 1},
          "completedAt": {"type": "string", "format": "date"}
        },
        "allOf": [
          {
            "if": {"properties": {"blockers": {"minItems": 1}}},
            "then": {"required": ["blockerOwner", "resumeCondition"]}
          },
          {
            "if": {"properties": {"status": {"const": "Done"}}},
            "then": {
              "required": ["completedAt", "resultSummary"],
              "properties": {"evidencePaths": {"minItems": 1}}
            }
          },
          {
            "if": {"required": ["plannedStart"]},
            "then": {"required": ["plannedEnd"]}
          },
          {
            "if": {"required": ["plannedEnd"]},
            "then": {"required": ["plannedStart"]}
          }
        ]
      }
    }
  }
}
