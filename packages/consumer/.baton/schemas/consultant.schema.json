{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/FabienGreard/baton/blob/main/packages/consumer/.baton/schemas/consultant.schema.json",
  "title": "Custom Consultant definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "headline",
    "domain",
    "readinessRequirements",
    "evidenceRequirements",
    "acceptanceAuthority"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "headline": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "readinessRequirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidenceRequirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptanceAuthority": {
      "type": "string",
      "minLength": 1
    }
  }
}
