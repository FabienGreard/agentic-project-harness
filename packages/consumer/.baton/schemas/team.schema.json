{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/FabienGreard/baton/blob/main/packages/consumer/.baton/schemas/team.schema.json",
  "title": "Baton team state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "recordType",
    "preset",
    "presetLabel",
    "commonNames",
    "management",
    "operations",
    "consultants",
    "contractorBench",
    "internalAudit",
    "reasoning",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "recordType": {
      "const": "team"
    },
    "preset": {
      "enum": [
        "game-development",
        "software-product",
        "business-operations",
        "research"
      ]
    },
    "presetLabel": {
      "type": "string",
      "minLength": 1
    },
    "commonNames": {
      "type": "object",
      "additionalProperties": false,
      "required": ["management", "operations", "consultants", "contractors", "internalAudit"],
      "properties": {
        "management": {"const": "Management"},
        "operations": {"const": "Operations"},
        "consultants": {"const": "Consultants"},
        "contractors": {"const": "Contractors"},
        "internalAudit": {"const": "Internal Audit"}
      }
    },
    "management": {
      "$ref": "#/$defs/permanentRole"
    },
    "operations": {
      "$ref": "#/$defs/permanentRole"
    },
    "consultants": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/consultant"
      }
    },
    "contractorBench": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/capability"
      }
    },
    "internalAudit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "headline", "projectTeamMember"],
      "properties": {
        "title": {"const": "Internal Audit"},
        "headline": {"type": "string", "minLength": 1},
        "projectTeamMember": {"const": false}
      }
    },
    "reasoning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["management", "operations", "consultants", "contractors", "internalAudit"],
      "properties": {
        "management": {"$ref": "#/$defs/reasoningLevel"},
        "operations": {"$ref": "#/$defs/reasoningLevel"},
        "consultants": {"$ref": "#/$defs/reasoningLevel"},
        "contractors": {"$ref": "#/$defs/reasoningLevel"},
        "internalAudit": {"$ref": "#/$defs/reasoningLevel"}
      }
    },
    "updatedAt": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "reasoningLevel": {
      "enum": ["inherit", "none", "minimal", "low", "medium", "high", "xhigh", "max", "ultra"]
    },
    "permanentRole": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commonName",
        "title",
        "headline",
        "configPath"
      ],
      "properties": {
        "commonName": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "headline": {
          "type": "string",
          "minLength": 1
        },
        "configPath": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "headline"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
        },
        "headline": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "consultant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "headline",
        "domain",
        "readinessRequirements",
        "evidenceRequirements",
        "acceptanceAuthority",
        "nonAuthorities",
        "source",
        "status",
        "configPath",
        "configBaselineSha256",
        "hiredAt",
        "firedAt",
        "preservedConfig",
        "manualAction"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"},
        "title": {"type": "string", "minLength": 1},
        "headline": {"type": "string", "minLength": 1},
        "domain": {"type": "string", "minLength": 1},
        "readinessRequirements": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "evidenceRequirements": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "acceptanceAuthority": {"type": "string", "minLength": 1},
        "nonAuthorities": {"type": "array", "minItems": 4, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "source": {"enum": ["preset", "custom"]},
        "status": {"enum": ["active", "inactive"]},
        "configPath": {"type": "string", "minLength": 1},
        "configBaselineSha256": {"type": "string"},
        "hiredAt": {"type": "string", "minLength": 1},
        "firedAt": {"type": "string"},
        "preservedConfig": {"type": "boolean"},
        "manualAction": {"type": "string"}
      }
    }
  }
}
